<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_page"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="276dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="228dp"
                android:scaleType="centerCrop"
                android:src="@drawable/detail_header_crane" />

            <View
                android:layout_width="match_parent"
                android:layout_height="228dp"
                android:background="#55000000" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@color/white">

                <ImageButton
                    android:id="@+id/detail_back_button"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="项目详情"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:drawableStart="@drawable/ic_share"
                    android:gravity="center"
                    android:text="分享"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_gravity="bottom"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/project_name_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="中建 · 未来城二期项目"
                        android:textColor="@color/white"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/project_status_text"
                        android:layout_width="58dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_chip_green"
                        android:gravity="center"
                        android:text="施工中"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/project_address_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="广州市天河区珠江新城中建路888号"
                    android:textColor="#E4ECF8"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="-18dp"
            android:background="@drawable/bg_card_round"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="项目进度"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/project_plan_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="计划竣工  2024-12-30"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/project_progress_text"
                    android:layout_width="62dp"
                    android:layout_height="wrap_content"
                    android:text="68%"
                    android:textColor="@color/dashboard_blue"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/project_progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="68"
                    android:progressDrawable="@drawable/bg_progress_layer" />

                <TextView
                    android:id="@+id/project_days_text"
                    android:layout_width="82dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="距离竣工 224天"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="12dp"
            android:columnCount="3">

            <TextView style="@style/DetailActionCard" android:drawableTop="@drawable/ic_doc" android:text="项目资料\n基本信息/合同" />
            <TextView
                android:id="@+id/drawing_docs_action"
                style="@style/DetailActionCard"
                android:drawableTop="@drawable/ic_project"
                android:text="图纸文档\n图纸查看/管理" />
            <TextView style="@style/DetailActionCard" android:drawableTop="@drawable/ic_people" android:text="项目成员\n成员管理/权限" />
            <TextView style="@style/DetailActionCard" android:drawableTop="@drawable/ic_doc" android:text="施工日志\n日志记录/查看" />
            <TextView style="@style/DetailActionCard" android:drawableTop="@drawable/ic_export" android:text="导出报表\n数据统计/导出" />
            <TextView style="@style/DetailActionCard" android:drawableTop="@drawable/ic_scan" android:text="二维码扫码\n现场扫码/巡检" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_round"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="最近文件" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="全部文件  >" android:textColor="@color/text_secondary" android:textSize="12sp" />
            </LinearLayout>

            <include layout="@layout/item_detail_file_pdf1" />
            <include layout="@layout/item_detail_file_pdf2" />
            <include layout="@layout/item_detail_file_xlsx" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="查看更多文件  >"
                android:textColor="@color/dashboard_blue"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
