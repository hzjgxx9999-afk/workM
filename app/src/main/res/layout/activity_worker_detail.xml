<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/worker_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_page"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <FrameLayout android:layout_width="match_parent" android:layout_height="46dp">
            <ImageButton android:id="@+id/back_button" android:layout_width="42dp" android:layout_height="42dp" android:layout_gravity="start|center_vertical" android:background="?attr/selectableItemBackgroundBorderless" android:padding="9dp" android:src="@drawable/ic_back" />
            <TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="center" android:gravity="center" android:text="工人详情" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:layout_width="42dp" android:layout_height="42dp" android:layout_gravity="end|center_vertical" android:gravity="center" android:text="..." android:textColor="@color/text_primary" android:textSize="18sp" />
        </FrameLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="236dp" android:layout_marginTop="10dp" android:background="@drawable/bg_blue_panel" android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="82dp" android:gravity="center_vertical" android:orientation="horizontal">
                <ImageView android:layout_width="70dp" android:layout_height="70dp" android:scaleType="centerCrop" android:src="@drawable/worker_avatar_zhang" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/worker_name_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="加载中" android:textColor="@color/white" android:textSize="25sp" android:textStyle="bold" />
                    <TextView android:id="@+id/worker_type_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="正在读取工人信息" android:textColor="#DDEBFF" android:textSize="14sp" />
                </LinearLayout>
                <TextView android:id="@+id/worker_status_text" android:layout_width="54dp" android:layout_height="24dp" android:background="@drawable/bg_success_pill" android:gravity="center" android:text="--" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#32FFFFFF" />
            <GridLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:columnCount="2">
                <TextView android:id="@+id/worker_team_text" style="@style/WorkerDetailInfo" android:text="所属班组\n--" />
                <TextView android:id="@+id/worker_leader_text" style="@style/WorkerDetailInfo" android:text="班组长\n--" />
                <TextView android:id="@+id/worker_project_text" style="@style/WorkerDetailInfo" android:text="项目名称\n--" />
                <TextView android:id="@+id/worker_mobile_text" style="@style/WorkerDetailInfo" android:text="手机号\n--" />
                <TextView android:id="@+id/worker_id_card_text" style="@style/WorkerDetailInfo" android:text="身份证号\n--" />
            </GridLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="112dp" android:layout_marginTop="12dp" android:background="@drawable/bg_card_stroke" android:orientation="vertical" android:padding="14dp">
            <TextView android:id="@+id/entry_progress_title_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="入场流程" android:textColor="@color/dashboard_blue" android:textSize="15sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="12dp" android:layout_weight="1" android:gravity="center" android:orientation="horizontal">
                <TextView android:id="@+id/identity_status_text" style="@style/FlowStep" android:text="·\n身份认证" />
                <TextView android:id="@+id/safety_status_text" style="@style/FlowStep" android:text="·\n安全培训" />
                <TextView android:id="@+id/health_status_text" style="@style/FlowStep" android:text="·\n健康检查" />
                <TextView android:id="@+id/contract_status_text" style="@style/FlowStep" android:text="·\n合同签署" />
                <TextView android:id="@+id/insurance_status_text" style="@style/FlowStep" android:text="·\n保险签署" />
            </LinearLayout>
        </LinearLayout>

        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:columnCount="2">
            <TextView style="@style/WorkerDetailCard" android:text="考勤记录\n本月出勤 26天\n本月工时 208.5小时" />
            <TextView style="@style/WorkerDetailCard" android:text="薪酬概况\n本月应发 6,480.00元\n已发 5,200.00元" />
            <TextView style="@style/WorkerDetailCard" android:text="违章记录\n本月违章 0次\n累计违章 0次" />
            <TextView style="@style/WorkerDetailCard" android:text="证件资料\n证件齐全\n证件有效期至 2025-05-10" />
        </GridLayout>

        <TextView android:id="@+id/edit_worker_button" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="14dp" android:background="@drawable/bg_outline_blue" android:gravity="center" android:text="编辑信息" android:textColor="@color/dashboard_blue" android:textSize="16sp" android:textStyle="bold" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
