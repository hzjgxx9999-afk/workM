<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/approval_reissue_card"
    android:layout_width="match_parent"
    android:layout_height="94dp"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_card_stroke"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">
    <TextView android:layout_width="38dp" android:layout_height="38dp" android:background="@drawable/bg_chip_blue" android:gravity="center" android:text="人" android:textColor="@color/dashboard_blue" android:textSize="16sp" android:textStyle="bold" />
    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="张伟" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="项目：中建 · 未来城二期项目" android:textColor="@color/text_secondary" android:textSize="11sp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="班组：钢筋班" android:textColor="@color/text_secondary" android:textSize="11sp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="申请时间：2024-05-20 08:45" android:textColor="@color/text_secondary" android:textSize="11sp" />
    </LinearLayout>
    <LinearLayout android:layout_width="68dp" android:layout_height="match_parent" android:gravity="center_vertical|end" android:orientation="vertical">
        <TextView android:layout_width="56dp" android:layout_height="24dp" android:background="@drawable/bg_status_soft_orange" android:gravity="center" android:text="补卡申请" android:textColor="#E87900" android:textSize="11sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="待审批" android:textColor="#F04438" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
